---
layout: null
---

<?xml version="1.0" encoding="UTF-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="en">
    <title>GameDev Tech Daily</title>
    <subtitle>Daily curated game development technical articles — Focus on Technical Design, UE5/Unity, Open World &amp; Toolchains</subtitle>
    <link href="{{ '/feed-en.xml' | absolute_url }}" rel="self"/>
    <link href="{{ '/' | absolute_url }}"/>
    <updated>{{ site.time | date_to_xmlschema }}</updated>
    <id>{{ '/' | absolute_url }}</id>
    <author>
        <name>GameDev Tech Daily</name>
    </author>
    <icon>{{ '/assets/images/favicon.ico' | absolute_url }}</icon>
    <logo>{{ '/assets/images/logo.png' | absolute_url }}</logo>
    
    {% for post in site.posts %}
    {% if post.path contains '-en' or post.lang == 'en' %}
    <entry>
        <title>{{ post.title | xml_escape }}</title>
        <link href="{{ post.url | absolute_url }}"/>
        <updated>{{ post.date | date_to_xmlschema }}</updated>
        <published>{{ post.date | date_to_xmlschema }}</published>
        <id>{{ post.url | absolute_url }}</id>
        <content type="html">{{ post.content | xml_escape }}</content>
        <summary>{{ post.content | strip_html | truncate: 200 | xml_escape }}</summary>
        {% for category in post.categories %}
        <category term="{{ category | xml_escape }}"/>
        {% endfor %}
    </entry>
    {% endif %}
    {% endfor %}
</feed>
